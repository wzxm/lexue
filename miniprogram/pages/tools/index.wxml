<view class="page">
  <!-- 顶部标题 -->
  <view class="page-header">
    <text class="page-title">百宝箱</text>
    <text class="page-subtitle">更多好用工具，助力学习成长</text>
  </view>

  <!-- 工具宫格（3列） -->
  <view class="tools-grid">
    <view
      class="tool-card"
      wx:for="{{toolList}}"
      wx:key="name"
      data-tool="{{item}}"
      bindtap="handleTool"
    >
      <view class="tool-icon-wrap" style="background:{{item.bgColor}};">
        <text class="iconfont tool-icon" style="color:{{item.iconColor}};">{{item.icon}}</text>
      </view>
      <text class="tool-name">{{item.name}}</text>
      <view wx:if="{{!item.available}}" class="coming-badge">
        <text class="coming-text">即将上线</text>
      </view>
      <view wx:else class="available-badge">
        <text class="available-text">可用</text>
      </view>
    </view>
  </view>
</view>
