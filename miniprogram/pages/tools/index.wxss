.page {
  min-height: 100vh;
  background: #F5F5F5;
}

/* ── 页面标题 ── */
.page-header {
  background: #FFFFFF;
  padding: 40rpx 32rpx 32rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #222222;
  margin-bottom: 10rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #999999;
}

/* ── 工具宫格（3列） ── */
.tools-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  gap: 20rpx;
}

.tool-card {
  width: calc(33.3333% - 14rpx);
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

.tool-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.tool-icon {
  font-size: 48rpx;
  line-height: 1;
}

.tool-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  text-align: center;
  margin-bottom: 12rpx;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coming-badge {
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 4rpx 12rpx;
}

.coming-text {
  font-size: 20rpx;
  color: #999999;
}

.available-badge {
  background: #E8F5E9;
  border-radius: 12rpx;
  padding: 4rpx 12rpx;
}

.available-text {
  font-size: 20rpx;
  color: #4CAF50;
}
