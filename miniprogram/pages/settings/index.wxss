.settings-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
}

/* ── 用户信息卡片 ── */
.user-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 36rpx 28rpx;
  margin-bottom: 24rpx;
  gap: 24rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: #00C853;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-avatar-text {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #222222;
}

.user-sub {
  font-size: 26rpx;
  color: #999999;
}

.user-card-arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  font-weight: 300;
}

/* ── 菜单列表 ── */
.menu-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  height: 104rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #F0FFF5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon {
  font-size: 36rpx;
}

.menu-label {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.menu-arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  font-weight: 300;
}

/* ── 版本号 ── */
.version-area {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.version-text {
  font-size: 24rpx;
  color: #CCCCCC;
}
