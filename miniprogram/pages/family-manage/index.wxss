.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 160rpx;
}
.header {
  background: #fff;
  padding: 40rpx 32rpx 32rpx;
  border-bottom: 1rpx solid #EEEEEE;
}
.title { display: block; font-size: 36rpx; font-weight: 600; color: #333; }
.subtitle { display: block; font-size: 24rpx; color: #999; margin-top: 8rpx; }
.loading, .empty {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 120rpx 0; color: #999;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; }
.member-list { margin-top: 16rpx; }
.member-item {
  display: flex; align-items: center;
  background: #fff; padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #EEEEEE;
}
.avatar-img { width: 88rpx; height: 88rpx; border-radius: 50%; }
.avatar-placeholder {
  width: 88rpx; height: 88rpx; border-radius: 50%;
  background: #00C853; display: flex;
  align-items: center; justify-content: center;
  color: #fff; font-size: 32rpx; font-weight: 600;
}
.member-info { flex: 1; margin-left: 24rpx; }
.member-name { display: block; font-size: 30rpx; color: #333; }
.role-tag {
  display: inline-block; margin-top: 8rpx;
  padding: 4rpx 16rpx; border-radius: 20rpx;
  font-size: 22rpx;
}
.role-owner { background: #E8F5E9; color: #00C853; }
.role-editor { background: #E3F2FD; color: #1976D2; }
.role-viewer { background: #F5F5F5; color: #999; }
.remove-btn { font-size: 26rpx; color: #FF5252; padding: 12rpx 0 12rpx 24rpx; }
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; padding: 24rpx 32rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.invite-btn {
  background: #00C853; color: #fff;
  border-radius: 16rpx; font-size: 32rpx;
  font-weight: 600; height: 96rpx; line-height: 96rpx;
}
