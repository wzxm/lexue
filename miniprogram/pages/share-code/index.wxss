.page {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 加载态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

/* 内容区 */
.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

/* ── 顶部标题区 ── */
.header-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #E8F5E9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.icon-emoji {
  font-size: 56rpx;
  line-height: 1;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #222222;
  margin-bottom: 16rpx;
}

.page-desc {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  line-height: 1.6;
}

/* ── 口令卡片 ── */
.code-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 32rpx 36rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 32rpx rgba(0, 200, 83, 0.15);
  border: 2rpx solid #E8F5E9;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.code-text {
  font-size: 80rpx;
  font-weight: 900;
  color: #00C853;
  letter-spacing: 24rpx;
  font-family: 'Courier New', monospace;
  margin-bottom: 20rpx;
}

.expire-badge {
  background: #F0FFF4;
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
}

.expire-text {
  font-size: 24rpx;
  color: #4CAF50;
}

/* ── 操作按钮 ── */
.btn-copy {
  width: 100%;
  height: 96rpx;
  background: #00C853;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  margin-top: 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 200, 83, 0.35);
}

.btn-copy::after { border: none; }

.btn-regen {
  font-size: 28rpx;
  color: #999999;
  text-decoration: underline;
  margin-bottom: 52rpx;
  padding: 16rpx;
}

/* ── 使用说明卡片 ── */
.tips-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  box-sizing: border-box;
}

.tips-header {
  margin-bottom: 28rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.tips-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.tips-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #E8F5E9;
  color: #00C853;
  font-size: 26rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  text-align: center;
  line-height: 48rpx;
}

.tips-content {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.6;
}

.tips-note {
  font-size: 24rpx;
  color: #AAAAAA;
  line-height: 1.6;
  display: block;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}
