<view class="page">
  <!-- 加载态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text class="loading-text">生成口令中...</text>
  </view>

  <!-- 内容区 -->
  <view wx:else class="content">

    <!-- 顶部图标 + 标题 -->
    <view class="header-area">
      <view class="icon-wrap">
        <text class="icon-emoji">🔑</text>
      </view>
      <text class="page-title">课表分享口令</text>
      <text class="page-desc">将口令发给家人，对方可复制你的课表</text>
    </view>

    <!-- 口令展示卡片 -->
    <view class="code-card">
      <text class="code-text">{{code}}</text>
      <view class="expire-badge">
        <text class="expire-text">7天有效 · 到期 {{expireAt}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <button class="btn-copy" bindtap="copyCode">复制口令</button>
    <text class="btn-regen" bindtap="regenerateCode">重新生成</text>

    <!-- 使用说明卡片 -->
    <view class="tips-card">
      <view class="tips-header">
        <text class="tips-title">📋 使用说明</text>
      </view>
      <view class="tips-list">
        <view class="tips-item">
          <text class="tips-num">1</text>
          <text class="tips-content">将口令发送给家人或朋友</text>
        </view>
        <view class="tips-item">
          <text class="tips-num">2</text>
          <text class="tips-content">对方打开乐学课表小程序</text>
        </view>
        <view class="tips-item">
          <text class="tips-num">3</text>
          <text class="tips-content">在课表页点击「输入口令」</text>
        </view>
        <view class="tips-item">
          <text class="tips-num">4</text>
          <text class="tips-content">输入口令即可复制课表数据</text>
        </view>
      </view>
      <text class="tips-note">* 口令分享不含学生个人隐私信息</text>
    </view>

  </view>
</view>
