.notify-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ── 分区 ── */
.section {
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #999999;
  font-weight: 500;
  padding: 0 8rpx 16rpx;
}

.setting-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

/* ── 设置行 ── */
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  min-height: 104rpx;
}

.setting-row.border-bottom {
  border-bottom: 1rpx solid #F5F5F5;
}

.setting-row.row-disabled {
  opacity: 0.38;
}

.setting-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.setting-icon {
  font-size: 40rpx;
  line-height: 1;
  flex-shrink: 0;
}

.setting-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.setting-label {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.setting-desc {
  font-size: 24rpx;
  color: #AAAAAA;
}

.picker-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.picker-text {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.picker-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  font-weight: 300;
}

/* ── 底部保存按钮 ── */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.06);
}

.btn-save {
  width: 100%;
  height: 96rpx;
  background: #00C853;
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-save[disabled] {
  background: #A5D6A7;
}

.btn-save::after { border: none; }
