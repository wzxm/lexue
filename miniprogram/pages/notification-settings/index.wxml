<view class="notify-page">

  <!-- 放学提醒 -->
  <view class="section">
    <text class="section-title">放学提醒</text>
    <view class="setting-card">
      <view class="setting-row border-bottom">
        <view class="setting-left">
          <text class="setting-icon">🏠</text>
          <view class="setting-info">
            <text class="setting-label">开启放学提醒</text>
            <text class="setting-desc">放学前提醒家长接孩子</text>
          </view>
        </view>
        <switch
          checked="{{afterSchoolEnabled}}"
          color="#00C853"
          bind:change="onAfterSchoolToggle"
        />
      </view>

      <view class="setting-row {{!afterSchoolEnabled ? 'row-disabled' : ''}}">
        <view class="setting-left">
          <text class="setting-icon">⏰</text>
          <text class="setting-label">提前提醒时间</text>
        </view>
        <picker
          mode="selector"
          range="{{minuteOptions}}"
          value="{{afterSchoolIndex}}"
          disabled="{{!afterSchoolEnabled}}"
          bind:change="onAfterSchoolPickerChange"
        >
          <view class="picker-value">
            <text class="picker-text">{{afterSchoolMinutes}} 分钟</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 上课提醒 -->
  <view class="section">
    <text class="section-title">上课提醒</text>
    <view class="setting-card">
      <view class="setting-row border-bottom">
        <view class="setting-left">
          <text class="setting-icon">📚</text>
          <view class="setting-info">
            <text class="setting-label">开启上课提醒</text>
            <text class="setting-desc">上课前提醒孩子准备好</text>
          </view>
        </view>
        <switch
          checked="{{classEnabled}}"
          color="#00C853"
          bind:change="onClassToggle"
        />
      </view>

      <view class="setting-row {{!classEnabled ? 'row-disabled' : ''}}">
        <view class="setting-left">
          <text class="setting-icon">⏰</text>
          <text class="setting-label">提前提醒时间</text>
        </view>
        <picker
          mode="selector"
          range="{{minuteOptions}}"
          value="{{classIndex}}"
          disabled="{{!classEnabled}}"
          bind:change="onClassPickerChange"
        >
          <view class="picker-value">
            <text class="picker-text">{{classMinutes}} 分钟</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="footer-bar">
    <button
      class="btn-save"
      disabled="{{loading}}"
      bind:tap="onSave"
    >
      {{loading ? '保存中...' : '保存设置'}}
    </button>
  </view>

</view>
