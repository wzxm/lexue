<view class="page">
  <scroll-view scroll-y class="page-scroll">
    <view class="hero-card">
      <view class="hero-badge">创建课表</view>
      <text class="hero-title">先录入第一节课</text>
      <text class="hero-desc">填完这张卡片，就能把课表正式建起来；后续课程可以继续补充。</text>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">基础信息</text>
        <text class="section-tip">必填</text>
      </view>

      <view class="field-row field-row--column border-bottom">
        <view class="field-label-wrap">
          <text class="field-label">课程名称</text>
          <text class="field-required">*</text>
        </view>
        <input
          class="field-input field-input--left"
          placeholder="例如：语文、数学、钢琴"
          placeholder-class="field-placeholder"
          value="{{name}}"
          bindinput="onNameInput"
          maxlength="20"
        />
      </view>

      <view class="field-row border-bottom">
        <view class="field-label-wrap">
          <text class="field-label">上课时间</text>
          <text class="field-required">*</text>
        </view>
        <view class="field-inline-pickers">
          <picker mode="selector" range="{{weekdayLabels}}" value="{{weekdayIndex}}" bindchange="onWeekdayChange">
            <view class="picker-chip">
              <text class="picker-chip-text">{{weekdayLabels[weekdayIndex]}}</text>
              <text class="picker-chip-arrow">▾</text>
            </view>
          </picker>
          <picker mode="selector" range="{{periodLabels}}" value="{{periodIndex}}" bindchange="onPeriodChange">
            <view class="picker-chip picker-chip--ghost">
              <text class="picker-chip-text">{{periodLabels[periodIndex]}}</text>
              <text class="picker-chip-arrow">▾</text>
            </view>
          </picker>
        </view>
      </view>

      <view class="field-row">
        <text class="field-label">单双周</text>
        <picker mode="selector" range="{{weekTypeOptions}}" range-key="label" value="{{weekTypeIndex}}" bindchange="onWeekTypeChange">
          <view class="picker-value">
            <text class="picker-value-text">{{weekTypeOptions[weekTypeIndex].label}}</text>
            <text class="picker-value-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">补充信息</text>
        <text class="section-tip">选填</text>
      </view>

      <view class="field-row border-bottom">
        <text class="field-label">任课老师</text>
        <input
          class="field-input"
          placeholder="填写老师姓名"
          placeholder-class="field-placeholder"
          value="{{teacher}}"
          bindinput="onTeacherInput"
          maxlength="20"
        />
      </view>

      <view class="field-row border-bottom">
        <text class="field-label">上课地点</text>
        <input
          class="field-input"
          placeholder="填写教室 / 培训地点"
          placeholder-class="field-placeholder"
          value="{{classroom}}"
          bindinput="onClassroomInput"
          maxlength="20"
        />
      </view>

      <view class="field-area">
        <view class="field-area-head">
          <text class="field-label">备注</text>
          <text class="field-count">{{note.length}}/50</text>
        </view>
        <textarea
          class="field-textarea"
          placeholder="例如：记得带画笔、穿校服"
          placeholder-class="field-placeholder"
          value="{{note}}"
          bindinput="onNoteInput"
          maxlength="50"
        />
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">课程颜色</text>
        <text class="section-tip">方便区分</text>
      </view>
      <view class="color-grid">
        <view
          wx:for="{{colors}}"
          wx:key="id"
          class="color-item {{color === item.id ? 'color-item--active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onColorSelect"
        >
          <view class="color-dot" style="background: {{item.bg}};"></view>
          <text wx:if="{{color === item.id}}" class="color-check">✓</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="footer">
    <button class="submit-btn" bindtap="onSave" loading="{{loading}}" disabled="{{loading}}">
      {{mode === 'edit' ? '保存修改' : '完成创建'}}
    </button>
  </view>
</view>
