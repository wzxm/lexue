page {
  background: #F4F7FB;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background:
    linear-gradient(180deg, #08C25E 0rpx, #DDF5E8 280rpx, #F4F7FB 560rpx);
}

.page-scroll {
  flex: 1;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.hero-card {
  padding: 36rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #12D66C 0%, #08C25E 100%);
  color: #FFFFFF;
  box-shadow: 0 16rpx 40rpx rgba(8, 194, 94, 0.22);
  margin-bottom: 24rpx;
}

.hero-badge {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
  margin-bottom: 18rpx;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 700;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.92);
}

.section-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 32rpx rgba(15, 23, 42, 0.05);
  overflow: hidden;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
}

.section-tip {
  font-size: 24rpx;
  color: #94A3B8;
}

.field-row {
  min-height: 108rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.field-row--column {
  min-height: auto;
  padding-top: 8rpx;
  padding-bottom: 24rpx;
  flex-direction: column;
  align-items: flex-start;
}

.border-bottom {
  border-bottom: 1rpx solid #EEF2F7;
}

.field-label-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.field-label {
  font-size: 30rpx;
  color: #1F2937;
  font-weight: 500;
  flex-shrink: 0;
}

.field-required {
  color: #FF5A5F;
  font-size: 28rpx;
}

.field-input {
  flex: 1;
  min-width: 0;
  text-align: right;
  height: 108rpx;
  font-size: 28rpx;
  color: #111827;
}

.field-input--left {
  width: 100%;
  height: 88rpx;
  margin-top: 18rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  text-align: left;
  background: #F8FAFC;
  border-radius: 20rpx;
}

.field-placeholder {
  color: #B6C0CC;
  font-size: 28rpx;
}

.field-inline-pickers {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.picker-chip {
  min-width: 140rpx;
  max-width: 320rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #EAFBF1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.picker-chip--ghost {
  background: #F8FAFC;
}

.picker-chip-text {
  font-size: 26rpx;
  color: #0F172A;
  line-height: 1.4;
}

.picker-chip-arrow,
.picker-value-arrow {
  color: #94A3B8;
  font-size: 24rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.picker-value-text {
  font-size: 28rpx;
  color: #0F172A;
}

.field-area {
  padding: 24rpx 28rpx 28rpx;
}

.field-area-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.field-count {
  font-size: 24rpx;
  color: #94A3B8;
}

.field-textarea {
  width: 100%;
  height: 180rpx;
  border-radius: 20rpx;
  background: #F8FAFC;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
  color: #111827;
}

.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding: 12rpx 28rpx 32rpx;
}

.color-item {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 2rpx solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
}

.color-item--active {
  border-color: #BBF7D0;
  box-shadow: 0 8rpx 20rpx rgba(8, 194, 94, 0.15);
}

.color-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
}

.color-check {
  position: absolute;
  right: 8rpx;
  top: 4rpx;
  font-size: 20rpx;
  line-height: 1;
  color: #08C25E;
  font-weight: 700;
}

.footer {
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #EAECEF;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  border: none;
  background: linear-gradient(135deg, #15D86F 0%, #08C25E 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 32rpx rgba(8, 194, 94, 0.22);
}

.submit-btn::after {
  border: none;
}
