/* 新建课表页面样式 */

.sf-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 120rpx;
}

/* ——— 步骤条 ——— */
.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 60rpx 32rpx;
  background: #FFFFFF;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #E8F9EF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: 2rpx solid #00C853;
}

.step-icon--inactive {
  background: #F5F5F5;
  border-color: #E0E0E0;
}

.step-label {
  font-size: 24rpx;
  color: #00C853;
  font-weight: 500;
}

.step-label--inactive {
  color: #BDBDBD;
}

.step-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(to right, #00C853, #E0E0E0);
  margin: 0 16rpx;
  margin-bottom: 28rpx; /* 对齐图标中心 */
}

/* ——— 卡片区块 ——— */
.section {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin: 24rpx 24rpx 0;
  overflow: hidden;
}

.section-title {
  font-size: 26rpx;
  color: #666666;
  padding: 24rpx 32rpx 8rpx;
}

/* ——— 列表行 ——— */
.list-item {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx;
  min-height: 100rpx;
}

.list-label {
  flex: 1;
  font-size: 30rpx;
  color: #1A1A1A;
}

.list-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.list-value {
  font-size: 30rpx;
  color: #666666;
}

.list-arrow {
  font-size: 36rpx;
  color: #BDBDBD;
}

.divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 0 32rpx;
}

/* ——— stepper ——— */
.stepper {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.stepper-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 1rpx solid #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #1A1A1A;
  background: #FFFFFF;
}

.stepper-btn--disabled {
  color: #BDBDBD;
  border-color: #F0F0F0;
}

.stepper-val {
  font-size: 32rpx;
  color: #1A1A1A;
  min-width: 48rpx;
  text-align: center;
  font-weight: 500;
}

/* ——— 时段标签 ——— */
.session-tag {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.session-tag--morning {
  background: #FFF3E0;
}

.session-tag--afternoon {
  background: #FFF8E1;
}

.session-tag--evening {
  background: #EDE7F6;
}

/* ——— 节次行 ——— */
.period-row {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx 20rpx 52rpx;
  background: #FAFAFA;
}

.period-label {
  flex: 1;
  font-size: 28rpx;
  color: #444444;
}

.period-time {
  font-size: 28rpx;
  color: #888888;
  margin-right: 8rpx;
}

.period-arrow {
  font-size: 32rpx;
  color: #BDBDBD;
}

/* ——— 底部保存按钮 ——— */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.save-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: #00C853;
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 500;
  border: none;
  line-height: 96rpx;
}

.save-btn--loading {
  background: #80E4A9;
}

.save-btn::after {
  border: none;
}

/* ——— Step 2 样式 ——— */
.step2-title {
  text-align: center;
  font-size: 32rpx;
  color: #333333;
  margin: 64rpx 0 24rpx;
  font-weight: 500;
}

.step2-footer {
  text-align: center;
  margin-top: 80rpx;
}

.add-later-text {
  font-size: 28rpx;
  color: #999999;
  padding: 20rpx;
}
