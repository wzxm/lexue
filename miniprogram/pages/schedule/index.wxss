/* ===== 空状态引导页 ===== */
.empty-guide {
  min-height: 100vh;
  /* background: #F5F5F5; */
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #07C160 0%, #E7F4FE 20%);
}
.guide-header {
  padding: 32rpx 32rpx 40rpx;
  background-color: transparent;
}
.guide-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #000000;
  margin-bottom: 24rpx;
}
/* 虚线占位图区域 */
.guide-placeholder {
  width: 100%;
  height: 100rpx;
  /* border: 2rpx dashed rgba(255,255,255,0.6); */
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}
.guide-placeholder-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}
.guide-subtitle {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
}
/* 白色功能区 */
.guide-body {
  /* background: #EEF6FF; */
  padding: 32rpx 24rpx 48rpx;
}
.feature-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 40rpx;
}
.feature-item {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 16rpx 40rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}
.feature-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}
.feature-icon { font-size: 56rpx; }
.feature-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}
.feature-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  line-height: 1.5;
}
.create-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100% !important;
  margin: 0;
  box-sizing: border-box;
  background: #07C160;
  color: #fff;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  height: 104rpx;
  /* line-height: 104rpx; */
  border: none;
}
.create-btn::after { border: none; }

/* ===== 有数据：课表视图 ===== */
.schedule-view {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fff;
}

/* Header 绿色渐变 */
.header {
  background: linear-gradient(180deg, #07C160 0%, #DFEAFE 100%);
  padding: 20rpx 24rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.header-icons {
  display: flex;
  gap: 16rpx;
}
.header-icon-btn {
  font-size: 44rpx;
  color: #fff;
  padding: 8rpx;
}
.header-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.student-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}
.student-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
}
.header-right { width: 80rpx; }

/* 网格区域 */
.grid-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 周次 + 表头行 */
.week-corner {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 10;
}
.grid-header-row {
  display: flex;
  margin-left: 80rpx;
  border-bottom: 1rpx solid #EEEEEE;
  background: #fff;
}
.grid-header-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 4rpx;
  border-right: 1rpx solid #EEEEEE;
}
.grid-header-cell--today {
  background: #07C160;
  border-radius: 8rpx 8rpx 0 0;
}
.grid-header-day {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}
.grid-header-cell--today .grid-header-day,
.grid-header-cell--today .grid-header-date {
  color: #fff;
}
.grid-header-date {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 周次角标 */
.week-corner-text {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
}

/* 课程行 */
.grid-body { flex: 1; }
.grid-row {
  display: flex;
  border-bottom: 1rpx solid #F0F0F0;
  min-height: 110rpx;
}
.period-cell {
  width: 80rpx;
  min-width: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 4rpx;
  border-right: 1rpx solid #EEEEEE;
  background: #FAFAFA;
}
.period-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  line-height: 1;
}
.period-time-line {
  font-size: 18rpx;
  color: #999;
  margin-top: 4rpx;
  line-height: 1.3;
}
.course-cell-wrap {
  flex: 1;
  border-right: 1rpx solid #F0F0F0;
  padding: 4rpx;
  display: flex;
  align-items: stretch;
}
.course-cell-wrap--today {
  background: #F6FFF9;
}
.course-block {
  flex: 1;
  border-radius: 10rpx;
  padding: 8rpx 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.course-block-name {
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
  line-height: 1.3;
}
.empty-cell {
  flex: 1;
  min-height: 100rpx;
}

/* ===== 课程详情 Modal ===== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 0 60rpx;
}
.modal-drag-bar {
  width: 80rpx; height: 8rpx;
  background: #E0E0E0;
  border-radius: 4rpx;
  margin: 20rpx auto 0;
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx 24rpx;
  border-bottom: 1rpx solid #EEEEEE;
}
.modal-title { font-size: 36rpx; font-weight: 700; color: #333; }
.modal-close { padding: 8rpx; color: #999; font-size: 32rpx; }
.modal-body { padding: 24rpx 40rpx; }
.info-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.info-label { font-size: 28rpx; color: #666; width: 160rpx; }
.info-value { font-size: 28rpx; color: #333; flex: 1; }
.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 40rpx 0;
}
.btn-edit {
  flex: 1;
  background: #E8F5E9;
  color: #00C853;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
}
.btn-delete {
  flex: 1;
  background: #FFF0F0;
  color: #FF5252;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
}
.btn-edit::after, .btn-delete::after { border: none; }
