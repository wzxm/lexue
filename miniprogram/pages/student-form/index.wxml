<view class="form-page">
  <scroll-view scroll-y class="form-body">

    <!-- 头像上传 -->
    <view class="avatar-section">
      <view class="avatar-upload" bindtap="onChooseAvatar">
        <view class="avatar-placeholder">
          <text class="avatar-camera">📷</text>
          <text class="avatar-hint">点击上传头像</text>
        </view>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="form-section">
      <view class="form-item border-bottom">
        <text class="form-label">姓名 <text class="required">*</text></text>
        <input
          class="form-input"
          placeholder="请输入学生姓名"
          placeholder-class="input-placeholder"
          value="{{name}}"
          data-field="name"
          bindinput="onInput"
          maxlength="20"
        />
      </view>
      <view class="form-item">
        <text class="form-label">学校 <text class="required">*</text></text>
        <input
          class="form-input"
          placeholder="请输入所在学校"
          placeholder-class="input-placeholder"
          value="{{school}}"
          data-field="school"
          bindinput="onInput"
          maxlength="30"
        />
      </view>
    </view>

    <!-- 班级信息 -->
    <view class="form-section">
      <view class="form-item border-bottom">
        <text class="form-label">年级 <text class="required">*</text></text>
        <picker mode="selector" range="{{gradeOptions}}" value="{{gradeIndex}}" bindchange="onGradeChange">
          <view class="picker-value">
            <text class="picker-text {{!gradeOptions[gradeIndex] ? 'picker-placeholder' : ''}}">
              {{gradeOptions[gradeIndex] || '请选择年级'}}
            </text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
      <view class="form-item">
        <text class="form-label">班级 <text class="required">*</text></text>
        <input
          class="form-input"
          placeholder="如：3班"
          placeholder-class="input-placeholder"
          value="{{classNum}}"
          data-field="classNum"
          bindinput="onInput"
          maxlength="10"
        />
      </view>
    </view>

    <!-- 可选信息 -->
    <view class="form-section">
      <view class="form-item border-bottom">
        <text class="form-label">入学年份</text>
        <input
          class="form-input"
          placeholder="选填"
          placeholder-class="input-placeholder"
          type="number"
          value="{{enrollYear}}"
          data-field="enrollYear"
          bindinput="onInput"
          maxlength="4"
        />
      </view>
      <view class="form-item">
        <text class="form-label">学号</text>
        <input
          class="form-input"
          placeholder="选填"
          placeholder-class="input-placeholder"
          value="{{studentNo}}"
          data-field="studentNo"
          bindinput="onInput"
          maxlength="20"
        />
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-section">
      <view class="form-item-textarea">
        <text class="form-label">备注</text>
        <textarea
          class="form-textarea"
          placeholder="选填，添加一些备注..."
          placeholder-class="input-placeholder"
          value="{{note}}"
          data-field="note"
          bindinput="onInput"
          maxlength="100"
        />
      </view>
    </view>

  </scroll-view>

  <!-- 底部保存按钮 -->
  <view class="form-footer">
    <button class="btn-primary" bindtap="onSave" loading="{{loading}}" disabled="{{loading}}">保存</button>
  </view>
</view>
