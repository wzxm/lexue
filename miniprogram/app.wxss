/* 乐学课表 - 全局样式 */

/* Iconfont 字体 */
@font-face {
  font-family: 'iconfont';
  src: url('//at.alicdn.com/t/c/font_5144485_9zctq5gxnc7.woff2?t=1774023877124') format('woff2'),
       url('//at.alicdn.com/t/c/font_5144485_9zctq5gxnc7.woff?t=1774023877124') format('woff'),
       url('//at.alicdn.com/t/c/font_5144485_9zctq5gxnc7.ttf?t=1774023877124') format('truetype');
  font-display: swap;
}

.iconfont {
  font-family: 'iconfont' !important;
  font-size: 16px;
  font-style: normal;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* CSS 变量 — 主题色统一在这里改，别到处散 */
page {
  --color-primary: #07C160;
  --color-primary-light: #E8F5E9;
  --color-bg: #F5F5F5;
  --color-card: #FFFFFF;
  --color-text-main: #333333;
  --color-text-sub: #666666;
  --color-text-gray: #999999;
  --color-border: #EEEEEE;
  --color-danger: #FF5252;

  background-color: var(--color-bg);
  color: var(--color-text-main);
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  display: flex;
  flex-direction: column;
}

/* WXSS 不支持 * 选择器，box-sizing 在 page 层设置 */
page {
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: var(--color-card);
  border-radius: 16rpx;
  padding: 24rpx;
}

/* 通用按钮 */
.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: 48rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  padding: 24rpx 0;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-ghost {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: 48rpx;
  text-align: center;
  font-size: 32rpx;
  padding: 24rpx 0;
}

.btn-ghost::after {
  border: none;
}

/* 页面安全区 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 通用分割线 */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 0 24rpx;
}

/* 文本截断 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}
