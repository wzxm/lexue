<view class="course-card" bindtap="onTap" style="border-left-color: {{course.color || '#00C853'}};">
  <view class="card-body">
    <view class="card-main">
      <text class="course-name">{{course.name}}</text>
      <text wx:if="{{course.teacher}}" class="course-meta">👤 {{course.teacher}}</text>
      <text wx:if="{{course.classroom}}" class="course-meta">📍 {{course.classroom}}</text>
    </view>
    <view class="card-side">
      <text class="period-badge">第{{course.period}}节</text>
    </view>
  </view>
  <text wx:if="{{course.note}}" class="course-note">{{course.note}}</text>
</view>
