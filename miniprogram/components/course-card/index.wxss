.course-card {
  background: #fff;
  border-left: 6rpx solid #00C853;
  border-radius: 0 16rpx 16rpx 0;
  padding: 24rpx 24rpx 24rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.card-body {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}
.card-main { flex: 1; }
.course-name {
  display: block;
  font-size: 32rpx; font-weight: 600;
  color: #333; margin-bottom: 8rpx;
}
.course-meta {
  display: block;
  font-size: 24rpx; color: #666;
  margin-bottom: 4rpx;
}
.card-side { margin-left: 24rpx; }
.period-badge {
  display: inline-block;
  background: #E8F5E9; color: #00C853;
  font-size: 22rpx; font-weight: 600;
  padding: 6rpx 16rpx; border-radius: 20rpx;
  white-space: nowrap;
}
.course-note {
  display: block;
  font-size: 22rpx; color: #999;
  margin-top: 12rpx; line-height: 1.5;
  border-top: 1rpx dashed #EEE;
  padding-top: 12rpx;
}
