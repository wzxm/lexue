.schedule-grid {
  width: 100%;
  overflow-x: auto;
}

/* ── 表头行 ── */
.header-row {
  display: flex;
  border-bottom: 2rpx solid #E8E8E8;
  background: #FAFAFA;
}

/* ── 节次标签列 ── */
.period-label-cell {
  width: 80rpx;
  min-width: 80rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 4rpx;
  background: #F0F0F0;
  border-right: 1rpx solid #E0E0E0;
}

.period-header-text {
  font-size: 24rpx;
  color: #999999;
  font-weight: 500;
}

.period-num {
  font-size: 26rpx;
  color: #555555;
  font-weight: 700;
}

.period-time {
  font-size: 22rpx;
  color: #AAAAAA;
  margin-top: 4rpx;
}

/* ── 日期表头格 ── */
.header-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 4rpx;
  border-right: 1rpx solid #EEEEEE;
}

.header-cell--today {
  background: #E8F5E9;
}

.header-day {
  font-size: 24rpx;
  color: #555555;
  font-weight: 600;
}

.header-date {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* ── 课程行 ── */
.grid-row {
  display: flex;
  border-bottom: 1rpx solid #EEEEEE;
  min-height: 104rpx;
}

/* ── 课程格 ── */
.grid-cell {
  flex: 1;
  min-height: 104rpx;
  border-right: 1rpx solid #EEEEEE;
  padding: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.grid-cell--today {
  background: #F4FEF7;
}

/* ── 课程块 ── */
.course-block {
  width: 100%;
  height: 100%;
  min-height: 96rpx;
  border-left: 4rpx solid #00C853;
  border-radius: 8rpx;
  padding: 8rpx 6rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.course-name {
  font-size: 24rpx;
  color: #222222;
  font-weight: 600;
  line-height: 1.4;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.course-teacher {
  font-size: 22rpx;
  color: #777777;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
