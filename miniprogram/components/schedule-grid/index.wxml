<view class="schedule-grid">
  <!-- 表头行 -->
  <view class="header-row">
    <view class="period-label-cell">
      <text class="period-header-text">节次</text>
    </view>
    <view
      class="header-cell {{item.isToday ? 'header-cell--today' : ''}}"
      wx:for="{{weekHeaders}}"
      wx:key="label"
    >
      <text class="header-day">{{item.label}}</text>
      <text class="header-date">{{item.date}}</text>
    </view>
  </view>

  <!-- 课程行 -->
  <view class="grid-row" wx:for="{{gridRows}}" wx:for-item="row" wx:key="index">
    <view class="period-label-cell">
      <text class="period-num">{{row.period.index}}</text>
      <text class="period-time">{{row.period.startTime}}</text>
    </view>
    <view
      class="grid-cell {{cell.isToday ? 'grid-cell--today' : ''}} {{cell.course ? 'grid-cell--has-course' : ''}}"
      wx:for="{{row.cells}}"
      wx:for-item="cell"
      wx:key="weekday"
      data-course="{{cell.course}}"
      data-weekday="{{cell.weekday}}"
      data-period-idx="{{cell.periodIdx}}"
      data-is-today="{{cell.isToday}}"
      bindtap="onTapCell"
    >
      <view
        wx:if="{{cell.course}}"
        class="course-block"
        style="border-left-color: {{cell.course.color || '#00C853'}}; background: {{cell.course.color ? cell.course.color + '18' : '#E8F5E920'}};"
      >
        <text class="course-name">{{cell.course.name}}</text>
        <text wx:if="{{cell.course.teacher}}" class="course-teacher">{{cell.course.teacher}}</text>
      </view>
    </view>
  </view>
</view>
